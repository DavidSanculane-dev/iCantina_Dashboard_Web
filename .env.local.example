# URL do projeto Supabase (sem /rest/v1/ no final)
SUPABASE_URL=https://uglbkfmjhyrvktkxjsiv.supabase.co

# Service Role Key -- pegue em Supabase > Project Settings > API > service_role
# NUNCA use o prefixo NEXT_PUBLIC_ nesta chave. Ela e secreta e so roda no servidor.
SUPABASE_SERVICE_ROLE_KEY=coloque_aqui_a_service_role_key

# String aleatoria longa, usada para assinar o cookie de sessao (gere com: openssl rand -base64 32)
SESSION_SECRET=troque_por_uma_string_aleatoria_longa
